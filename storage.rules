rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper to check ownership & authentication
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper to validate image file types
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    // Helper to validate size limits (5MB)
    function isValidSize() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // Listings images
    match /listings/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId) && isValidSize() && isImage();
    }

    // Profile photos
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true; // Publicly readable avatars
      allow write: if isOwner(userId) && isValidSize() && isImage();
    }

    // Report evidence
    match /evidence/{userId}/{allPaths=**} {
      allow read: if request.auth != null; // Only logged in users/admins
      allow write: if isOwner(userId) && isValidSize() && (isImage() || request.resource.contentType == 'application/pdf');
    }

    // Support uploads
    match /support/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId) && isValidSize() && (isImage() || request.resource.contentType == 'application/pdf');
    }
  }
}
