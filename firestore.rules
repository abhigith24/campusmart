rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasRole(role) {
      return request.auth != null && getRole() == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isSupport() {
      return hasRole('support');
    }

    function isSupportOrAdmin() {
      return request.auth != null && (getRole() == 'admin' || getRole() == 'support');
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.role == 'user';
      allow update: if request.auth != null && (
        (isAdmin() && (!('role' in request.resource.data) || request.resource.data.role in ['user', 'support', 'admin'])) ||
        (
          request.auth.uid == userId && 
          (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
        ) ||
        // Any logged-in user can update only rating/totalRatings fields (for rating system)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'totalRatings'])
      );
      allow delete: if isAdmin();
    }

    // ── Listings ───────────────────────────────────────────────────────────
    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.images is list &&
        request.resource.data.images.size() > 0;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) ||
        (request.auth != null && (
          isAdmin() ||
          (resource.data.sellerId == request.auth.uid &&
           resource.data.status != 'sold' &&
           request.resource.data.images is list &&
           request.resource.data.images.size() > 0) ||
          (resource.data.sellerId == request.auth.uid &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
        ));
      allow delete: if request.auth != null &&
        (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    // ── Chats ──────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.participants || isAdmin()
      );
      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        allow delete: if isAdmin();
      }
    }

    // ── Wishlists ──────────────────────────────────────────────────────────
    match /wishlists/{wishlistId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.userId ||
        isAdmin()
      );
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isAdmin());
    }

    // ── Notifications ──────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.sellerId ||
        request.auth.uid == resource.data.buyerId  ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.sellerId ||
        request.auth.uid == resource.data.buyerId  ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Purchase Requests ──────────────────────────────────────────────────
    match /purchaseRequests/{requestId} {
      allow read: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.sellerId ||
        request.auth.uid == resource.data.buyerId  ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.sellerId || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Ratings ────────────────────────────────────────────────────────────
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.buyerId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Reports ────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }
    match /sellerReports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // ── Activity Logs ──────────────────────────────────────────────────────
    match /activityLogs/{logId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // ── Support Tickets ────────────────────────────────────────────────────
    match /supportTickets/{ticketId} {
      allow create: if request.auth != null;
      allow read, update: if isSupportOrAdmin();
    }

    // ── Support Requests (Contact Page) ────────────────────────────────────
    match /support_requests/{reqId} {
      allow create: if true;
      allow read, update: if isSupportOrAdmin();
    }
    match /bug_reports/{reqId} {
      allow create: if true;
      allow read, update: if isSupportOrAdmin();
    }
    match /feature_requests/{reqId} {
      allow create: if true;
      allow read, update: if isSupportOrAdmin();
    }

  }
}
