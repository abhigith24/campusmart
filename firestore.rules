rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── CORE HELPERS & RBAC ───────────────────────────────────────────────
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole() {
      return getUserData().role;
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    function isSupportOrAdmin() {
      return isAuthenticated() && (getRole() == 'admin' || getRole() == 'support');
    }

    function isUnchanged(key) {
      return !(key in request.resource.data) || 
        (key in resource.data && request.resource.data[key] == resource.data[key]);
    }

    // ── USERS COLLECTION ───────────────────────────────────────────────────
    
    function validateUserSchema(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             data.role is string && (data.role == 'user' || data.role == 'support' || data.role == 'admin') &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 20)) &&
             (!('college' in data) || (data.college is string && data.college.size() <= 200)) &&
             (!('branch' in data) || (data.branch is string && data.branch.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('rating' in data) || (data.rating is int || data.rating is float)) &&
             (!('totalRatings' in data) || data.totalRatings is int) &&
             (!('joinedAt' in data) || data.joinedAt is timestamp) &&
             (!('lastLoginAt' in data) || data.lastLoginAt is timestamp) &&
             (!('collegeVerified' in data) || data.collegeVerified is bool) &&
             (!('banned' in data) || data.banned is bool) &&
             (!('successfulSales' in data) || data.successfulSales is int);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && request.auth.uid == userId
                    && validateUserSchema(request.resource.data)
                    && request.resource.data.role == 'user'
                    && (!('banned' in request.resource.data) || request.resource.data.banned == false);
                    
      allow update: if isAuthenticated() && (
        // Admin overrides
        (isAdmin() && validateUserSchema(request.resource.data)) ||
        // Owner updates profile (excluding sensitive fields)
        (
          request.auth.uid == userId &&
          validateUserSchema(request.resource.data) &&
          isUnchanged('email') &&
          isUnchanged('role') &&
          isUnchanged('joinedAt') &&
          isUnchanged('banned') &&
          isUnchanged('rating') &&
          isUnchanged('totalRatings')
        ) ||
        // External buyer updates seller's rating fields (rating system only)
        (
          request.auth.uid != userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'totalRatings']) &&
          (request.resource.data.rating is int || request.resource.data.rating is float) &&
          request.resource.data.totalRatings is int
        )
      );
      
      allow delete: if isAdmin();
    }

    // ── LISTINGS ───────────────────────────────────────────────────────────
    
    function validateListingSchema(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             (data.price is int || data.price is float) && data.price >= 0 &&
             data.sellerId is string &&
             data.images is list && data.images.size() > 0 && data.images.size() <= 10 &&
             data.status is string && (data.status == 'active' || data.status == 'reserved' || data.status == 'sold' || data.status == 'exchanged' || data.status == 'removed' || data.status == 'inactive') &&
             data.createdAt is timestamp &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('category' in data) || data.category is string) &&
             (!('condition' in data) || data.condition is string) &&
             (!('views' in data) || data.views is int) &&
             (!('listingType' in data) || (data.listingType == 'sell' || data.listingType == 'rent' || data.listingType == 'share' || data.listingType == 'donate')) &&
             (!('rentPerDay' in data) || (data.rentPerDay is int || data.rentPerDay is float));
    }

    match /listings/{listingId} {
      allow read: if true;
      
      allow create: if isAuthenticated() 
        && request.resource.data.sellerId == request.auth.uid
        && validateListingSchema(request.resource.data);
        
      allow update: if (
        // Increment views (anyone)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
        request.resource.data.views is int
      ) || (
        isAuthenticated() && (
          // Admin override
          (isAdmin() && validateListingSchema(request.resource.data)) ||
          // Owner update
          (
            resource.data.sellerId == request.auth.uid &&
            validateListingSchema(request.resource.data) &&
            isUnchanged('sellerId') &&
            isUnchanged('createdAt')
          )
        )
      );
      
      allow delete: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    // ── CHATS ──────────────────────────────────────────────────────────────
    
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.participants || isAdmin()
      );
      
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants is list &&
        request.resource.data.participants.size() == 2;
        
      allow update: if isAuthenticated() && (
        (request.auth.uid in resource.data.participants && isUnchanged('participants') && isUnchanged('listingId')) ||
        isAdmin()
      );
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants ||
          chatId.split('_')[0] == request.auth.uid ||
          chatId.split('_')[1] == request.auth.uid ||
          isAdmin()
        );
        
        allow create: if isAuthenticated() 
          && request.resource.data.senderId == request.auth.uid
          && (
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants ||
            chatId.split('_')[0] == request.auth.uid ||
            chatId.split('_')[1] == request.auth.uid
          );
          
        allow delete: if isAdmin();
      }
    }

    // ── WISHLISTS ──────────────────────────────────────────────────────────
    
    match /wishlists/{wishlistId} {
      allow create: if isAuthenticated() &&
        request.auth.uid == request.resource.data.userId;
        
      allow read: if isAuthenticated() && (
        resource == null ||
        request.auth.uid == resource.data.userId ||
        isAdmin()
      );
      
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // ── NOTIFICATIONS ──────────────────────────────────────────────────────
    
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (
        resource == null ||
        request.auth.uid == resource.data.sellerId ||
        request.auth.uid == resource.data.buyerId ||
        isAdmin()
      );
      
      allow create: if isAuthenticated() && (
        request.resource.data.buyerId == request.auth.uid ||
        request.resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
      
      allow update: if isAuthenticated() && (
        // Only recipient (either buyer or seller) may mark notifications as read
        (
          (request.auth.uid == resource.data.sellerId || request.auth.uid == resource.data.buyerId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
          request.resource.data.read is bool
        ) ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    // ── PURCHASE REQUESTS ──────────────────────────────────────────────────
    
    function isValidPurchaseRequestTransition(currentStatus, newStatus) {
      return currentStatus == newStatus ||
             (currentStatus == 'PENDING' && (newStatus == 'ACCEPTED' || newStatus == 'DECLINED' || newStatus == 'CANCELLED')) ||
             (currentStatus == 'ACCEPTED' && (newStatus == 'EXCHANGED' || newStatus == 'CANCELLED'));
    }

    match /purchaseRequests/{requestId} {
      allow read: if isAuthenticated() && (
        resource == null ||
        request.auth.uid == resource.data.sellerId ||
        request.auth.uid == resource.data.buyerId ||
        isAdmin()
      );
      
      allow create: if isAuthenticated() &&
        request.resource.data.buyerId == request.auth.uid &&
        request.resource.data.status == 'PENDING';
        
      allow update: if isAuthenticated() && (
        // Allow transition changes
        (
          (request.auth.uid == resource.data.sellerId || request.auth.uid == resource.data.buyerId) &&
          isValidPurchaseRequestTransition(resource.data.status, request.resource.data.status) &&
          isUnchanged('buyerId') &&
          isUnchanged('sellerId') &&
          isUnchanged('listingId') &&
          isUnchanged('createdAt')
        ) ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    // ── RATINGS ────────────────────────────────────────────────────────────
    
    match /ratings/{ratingId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() &&
        request.auth.uid == request.resource.data.buyerId &&
        request.resource.data.rating is int &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5 &&
        request.resource.data.review is string &&
        request.resource.data.review.size() <= 500;
        
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── REPORTS ────────────────────────────────────────────────────────────
    
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }
    
    match /sellerReports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update: if isSupportOrAdmin();
      allow delete: if isAdmin();
    }

    // ── ACTIVITY LOGS ──────────────────────────────────────────────────────
    
    match /activityLogs/{logId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ── SUPPORT TICKETS ────────────────────────────────────────────────────
    
    match /supportTickets/{ticketId} {
      allow create: if isAuthenticated();
      allow read, update: if isSupportOrAdmin();
      allow delete: if isAdmin();
    }

    // ── SUPPORT REQUESTS (CONTACT PAGE) ────────────────────────────────────
    
    match /support_requests/{reqId} {
      allow create: if true;
      allow read, update: if isSupportOrAdmin();
      allow delete: if isAdmin();
    }
    
    match /bug_reports/{reqId} {
      allow create: if true;
      allow read, update: if isSupportOrAdmin();
      allow delete: if isAdmin();
    }
    
    match /feature_requests/{reqId} {
      allow create: if true;
      allow read, update: if isSupportOrAdmin();
      allow delete: if isAdmin();
    }

    // ── ANALYTICS COLLECTIONS ──────────────────────────────────────────────
    
    match /feedback/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /aiAnalytics/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /shareClicksLog/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /shareActionsLog/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }
  }
}
