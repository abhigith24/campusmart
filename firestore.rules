rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Listings ───────────────────────────────────────────────────────────
    match /listings/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        // Admin can do anything
        isAdmin() ||
        // View count bump — anyone
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) ||
        // Owner updates — BUT NOT if already sold
        (resource.data.sellerId == request.auth.uid &&
         resource.data.status != 'sold') ||
        // Owner marking as sold or deleted (status change only)
        (resource.data.sellerId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
      );
      allow delete: if request.auth != null &&
        (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    // ── Chats ──────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.participants || isAdmin()
      );
      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        allow delete: if isAdmin();
      }
    }

    // ── Wishlists ──────────────────────────────────────────────────────────
    match /wishlists/{wishlistId} {
      allow read, create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow read, delete: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isAdmin());
    }

    // ── Notifications ──────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.sellerId ||
        request.auth.uid == resource.data.buyerId  ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.sellerId ||
        request.auth.uid == resource.data.buyerId  ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Purchase Requests ──────────────────────────────────────────────────
    match /purchaseRequests/{requestId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.sellerId ||
        request.auth.uid == resource.data.buyerId  ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.sellerId || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Ratings (one per listing per buyer, buyer only) ────────────────────
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.buyerId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Support Tickets ────────────────────────────────────────────────────
    match /supportTickets/{ticketId} {
      allow create: if request.auth != null;
      allow read, update: if isAdmin();
    }
  }
}
